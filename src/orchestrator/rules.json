{
  "states": [
    "AUDIT",
    "PATCH",
    "TEST",
    "COMMIT",
    "ERROR"
  ],
  "transitions": {
    "AUDIT": {
      "on_success": "PATCH",
      "on_failure": "ERROR"
    },
    "PATCH": {
      "on_success": "TEST",
      "on_failure": "ERROR"
    },
    "TEST": {
      "on_success": "COMMIT",
      "on_failure": "PATCH",
      "on_error": "ERROR"
    },
    "COMMIT": {
      "on_success": "COMPLETED",
      "on_failure": "ERROR"
    }
  },
  "retry_thresholds": {
    "max_patch_test_retries": 3,
    "sandbox_timeout_seconds": 30
  },
  "consensus_criteria": {
    "require_clean_tests": true,
    "require_zero_exit_code": true
  },
  "enable_atomic_rollbacks": true
}
